# ============================================================
# AliveDB — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# For Vercel, set these in the Vercel dashboard under Settings > Environment Variables.

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------

# Local development (SQLite file — zero setup)
DATABASE_URL="file:./dev.db"

# Production (Turso — never pauses on inactivity, free tier available)
# Create a free database at https://turso.tech
# DATABASE_URL="libsql://[your-db-name]-[your-org].turso.io"
DATABASE_AUTH_TOKEN=""

# ------------------------------------------------------------
# PING ENGINE
# ------------------------------------------------------------

# Timeout for each ping request in milliseconds (default: 10000 = 10s)
PING_TIMEOUT_MS=10000

# Maximum retry attempts on ping failure (default: 2)
PING_MAX_RETRIES=2

# ------------------------------------------------------------
# CRON SECURITY
# ------------------------------------------------------------

# Secret token to protect the /api/cron/ping and /api/keepalive endpoints.
# On Vercel, this is automatically sent by the Vercel cron system as:
#   Authorization: Bearer <secret>
#
# For external cron services (cron-job.org, UptimeRobot, GitHub Actions),
# include this same token in the Authorization header when calling /api/keepalive.
#
# NOTE: Vercel Hobby plan cron runs ONCE PER DAY only.
# For more frequent pings, set up an external cron service to call /api/keepalive.
# See README.md for setup instructions.
#
# Generate a strong secret: openssl rand -base64 32
CRON_SECRET="change-this-to-a-strong-random-secret"

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------

# Your deployed app URL (used for internal references)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------
# SECURITY / BASIC AUTH
# ------------------------------------------------------------

# Set these variables on your hosted instance (e.g. Vercel) to password-protect
# your dashboard. If left empty, password protection will be disabled (useful for local dev).
# BASIC_AUTH_USER="admin"
# BASIC_AUTH_PASSWORD="your-secure-password"

# ------------------------------------------------------------
# SUPABASE ANON KEY (per-project, not an env variable)
# ------------------------------------------------------------
#
# The Supabase anon (public) key is configured PER PROJECT in the AliveDB
# dashboard — not here — because you may monitor multiple Supabase projects
# with different keys.
#
# WHY IT'S REQUIRED:
#   Without the anon key, pings to /rest/v1/ return 401 Unauthorized.
#   That 401 is rejected at the API gateway BEFORE reaching the database.
#   Supabase only counts real database queries as "activity", so
#   unauthenticated pings do NOT prevent your project from being paused.
#
# WHERE TO FIND IT:
#   Supabase Dashboard → Settings → API → Project API keys → anon (public)
#
# HOW TO SET IT:
#   In the AliveDB dashboard, edit your project and paste the key into
#   the "Supabase Anon Key" field. Set health endpoint to /rest/v1/
