# ============================================================
# AliveDB — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# For Vercel, set these in the Vercel dashboard under Settings > Environment Variables.

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------

# Local development (SQLite file — zero setup)
DATABASE_URL="file:./dev.db"

# Production (Turso — never pauses on inactivity, free tier available)
# Create a free database at https://turso.tech
# DATABASE_URL="libsql://[your-db-name]-[your-org].turso.io"
DATABASE_AUTH_TOKEN=""

# ------------------------------------------------------------
# PING ENGINE
# ------------------------------------------------------------

# Timeout for each ping request in milliseconds (default: 10000 = 10s)
PING_TIMEOUT_MS=10000

# Maximum retry attempts on ping failure (default: 2)
PING_MAX_RETRIES=2

# ------------------------------------------------------------
# CRON SECURITY
# ------------------------------------------------------------

# Secret token to protect the /api/cron/ping endpoint from unauthorized triggers.
# On Vercel, this is automatically sent by the Vercel cron system.
# For manual triggers or self-hosting, include this as Authorization: Bearer <secret>
# Generate a strong secret: openssl rand -base64 32
CRON_SECRET="change-this-to-a-strong-random-secret"

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------

# Your deployed app URL (used for internal references)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
